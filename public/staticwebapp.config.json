      "rewrite": "/index.html"
    },
    {
      "route": "/lockers",
      "rewrite": "/index.html"
    },
    {
      "route": "/inventory",
      "rewrite": "/index.html"
    },
    {
      "route": "/approvals",
      "rewrite": "/index.html"
    },
    {
      "route": "/additem",
      "rewrite": "/index.html"
    },
    {
      "route": "/adduser",
      "rewrite": "/index.html"
    },
    {
      "route": "/profile",
      "rewrite": "/index.html"
    }
  ],
  "mimeTypes": {
    ".json": "text/json"
  }
}
