    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.css", "/*.js", "/*.json", "/*.svg", "/*.png", "/*.jpg", "/*.gif", "/*.ico"]
  },
  "routes": [
    {
      "route": "/master/*",
      "rewrite": "/index.html"
    },
    {
